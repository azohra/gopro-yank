# Copy to .env and fill in. Cookies expire periodically; refresh when you see HTTP 401.
#
# How to get these (see README for details):
#   1. Log into https://gopro.com/media-library/ in your browser
#   2. Open DevTools (Cmd+Opt+I on Mac, Ctrl+Shift+I elsewhere)
#   3. Application tab > Storage > Cookies > https://gopro.com
#   4. Copy the Value column for each cookie below

AUTH_TOKEN=eyJhbGciOi...replace-with-gp_access_token-value
USER_ID=00000000-0000-0000-0000-000000000000
